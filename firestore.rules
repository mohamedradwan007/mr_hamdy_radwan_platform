rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: main
    // Fields:
    //   - siteName: string
    //   - siteSubtitle: string
    //   - examsLink: string
    //   - showContact: boolean
    //   - contactDetails: map
    //   - heroTitle: string
    //   - heroSubtitle: string
    //
    // Collection: videos
    // Document ID: {videoId}
    // Fields:
    //   - id: number
    //   - title: string
    //   - unit: string
    //   - level: string
    //   - duration: string
    //   - views: string
    //   - ytLink: string
    //
    // Collection: students
    // Document ID: {studentId} (usually phone number)
    // Fields:
    //   - phone: string
    //   - name: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "mohamed.radwannn0@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /config/main {
      allow read: if true; // Publicly readable for the site to load
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true; // Publicly readable for students
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Allow reading specific student by ID for login check
      // In a real app, we'd use Firebase Auth for students too, 
      // but keeping the current logic:
      allow get: if true; 
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /honor_roll/{studentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
